{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "ApplicationName": "Chimin&Ungi",
    "MaxProductsPerPage": 20,
    "EnableProductLogging": true

  },

  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "RateLimiting": {
    "PermitLimit": 100000,
    "WindowMinutes": 1,
    "QueueLimit": 0
  }

}
/*

  Trace - максимально детальна інформація
  Debug - інформація для розробки
  Information - будь-яка інформація
  Warning - попередження
  Error - помилки
  Critical - критичні помилки
*/
